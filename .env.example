# ============================================================
# findabusiness.com.au — Environment variables
# Copy to .env.local for local dev and fill in. Never commit real secrets.
# ============================================================

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL (used for canonical/OG/sitemap). Optional in dev.
NEXT_PUBLIC_SITE_URL=https://findabusiness.com.au

# --- Server-only secrets ---
# Supabase service role key — bypasses RLS. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key for the /get-listed chat intake.
ANTHROPIC_API_KEY=
# Optional: override the chat model (defaults to claude-3-5-haiku-latest).
CHAT_MODEL=

# Google Maps Embed API key (restrict to your domain in Google Console).
GOOGLE_MAPS_API_KEY=

# Resend transactional email.
RESEND_API_KEY=

# Slack incoming webhook for new-listing / new-review alerts.
SLACK_WEBHOOK_URL=

# Upstash Redis (rate limiting). Without these, rate limiting no-ops in dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin account email — the chat/admin notifications + admin auth allowlist.
ADMIN_EMAIL=
